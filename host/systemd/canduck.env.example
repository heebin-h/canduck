# /etc/canduck/canduck.env 에 복사 후 값 수정
# systemd가 읽어 데몬에 환경변수로 주입.

CANDUCK_UART_DEVICE=/dev/ttyAMA0
CANDUCK_UART_BAUD=115200

CANDUCK_MQTT_HOST=localhost
CANDUCK_MQTT_PORT=1883

CANDUCK_LCD_SPI_BUS=0
CANDUCK_LCD_SPI_DEV=0

CANDUCK_LOG_LEVEL=INFO

# Voice (선택)
CANDUCK_ENABLE_VOICE=false
CANDUCK_PORCUPINE_ACCESS_KEY=
CANDUCK_WAKE_WORD_PATH=
